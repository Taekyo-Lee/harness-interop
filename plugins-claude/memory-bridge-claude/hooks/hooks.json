{
  "description": "Sync Claude Code memory to OpenCode on session end",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-bridge.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
